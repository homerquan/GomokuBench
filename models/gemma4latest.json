{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "openrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenRouter",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1",
        "apiKeyEnv": "OPENROUTER_API_KEY"
      },
      "models": {
        "gemma4:latest": {
          "name": "Gemma 4 26B A4B IT (OpenRouter)",
          "model": "google/gemma-4-26b-a4b-it:free",
          "tools": true,
          "extra_body": {
            "reasoning": {
              "enabled": true
            }
          }
        }
      }
    }
  }
}

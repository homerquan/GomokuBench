{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "nvidia": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "NVIDIA NIM",
      "options": {
        "baseURL": "https://integrate.api.nvidia.com/v1",
        "apiKeyEnv": "NVIDIA_API_KEY"
      },
      "models": {
        "mistral-medium-3.5-128b-nvidia-api-fast": {
          "name": "Mistral Medium 3.5 128B (NVIDIA, Fast)",
          "model": "mistralai/mistral-medium-3.5-128b",
          "tools": false,
          "rate_limit_rpm": 20,
          "timeout_seconds": 180,
          "extra_body": {
            "reasoning_effort": "none",
            "max_tokens": 1024,
            "temperature": 0,
            "top_p": 1.0,
            "stream": false
          }
        }
      }
    }
  }
}

{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "openrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenRouter",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1",
        "apiKeyEnv": "OPENROUTER_API_KEY"
      },
      "models": {
        "minimax-m2.5": {
          "name": "MiniMax M2.5",
          "model": "minimax/minimax-m2.5:free",
          "tools": true,
          "extra_body": {
            "reasoning": {
              "enabled": true
            }
          }
        }
      }
    }
  }
}

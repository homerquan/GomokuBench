{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "huggingface-router": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Hugging Face Router",
      "options": {
        "baseURL": "https://router.huggingface.co/v1",
        "apiKeyEnv": "HF_TOKEN"
      },
      "models": {
        "kimi-k2.6-novita": {
          "name": "Kimi K2.6 (Novita via HF Router)",
          "model": "moonshotai/Kimi-K2.6:novita",
          "tools": true
        }
      }
    }
  }
}

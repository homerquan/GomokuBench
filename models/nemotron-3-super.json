{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "openrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenRouter",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1",
        "apiKeyEnv": "OPENROUTER_API_KEY"
      },
      "models": {
        "nemotron-3-super": {
          "name": "Nemotron 3 Super",
          "model": "nvidia/nemotron-3-super-120b-a12b:free",
          "tools": true,
          "extra_body": {
            "reasoning": {
              "enabled": true
            }
          }
        }
      }
    }
  }
}

{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "openrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenRouter",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1",
        "apiKeyEnv": "OPENROUTER_API_KEY"
      },
      "models": {
        "grok-4.1-fast": {
          "name": "Grok 4.1 Fast (OpenRouter)",
          "model": "x-ai/grok-4.1-fast",
          "tools": true,
          "extra_body": {
            "reasoning": {
              "enabled": true
            }
          }
        }
      }
    }
  }
}

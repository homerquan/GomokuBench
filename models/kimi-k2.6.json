{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "openrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenRouter",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1",
        "apiKeyEnv": "OPENROUTER_API_KEY"
      },
      "models": {
        "kimi-k2.6": {
          "name": "Kimi K2.6 (OpenRouter)",
          "model": "moonshotai/kimi-k2.6",
          "tools": true,
          "extra_body": {
            "reasoning": {
              "enabled": true
            }
          }
        }
      }
    }
  }
}

{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "openai": {
      "npm": "openai",
      "name": "OpenAI",
      "options": {
        "baseURL": "https://api.openai.com/v1",
        "apiKeyEnv": "OPENAI_API_KEY"
      },
      "models": {
        "gpt-5-mini": {
          "name": "gpt-5-mini",
          "model": "gpt-5-mini",
          "tools": true
        }
      }
    }
  }
}
